# VITE_EMAIL_VERIFY_FUNCTION_URL=https://us-central1-your-project-id.cloudfunctions.net/sendEmailVerification
VITE_EMAIL_VERIFY_FUNCTION_URL=

# Existing key used by vite.config.ts
GEMINI_API_KEY=
