# Frontend (Vite)
VITE_API_URL=http://localhost:4000
VITE_API_BASE_URL=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=humanpartner

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
