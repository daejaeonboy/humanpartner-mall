# Firebase Admin SDK 설정
# 옵션 1: 서비스 계정 JSON 직접 입력 (한 줄로)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# 옵션 2: 개별 환경변수로 설정
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n여기에-private-key-입력\n-----END PRIVATE KEY-----\n"

# 서버 포트
PORT=4000

# Email (server/src/routes/emailRoutes.ts)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASS=
